# ============================================================
#  Canteen Backend — Environment Configuration
# ============================================================

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=canteen_db
DB_USER=postgres
DB_PASSWORD=postgres

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Security — CHANGE before production!
SECRET_KEY=canteen_super_secret_key_change_in_prod
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
